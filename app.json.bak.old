{
  "expo": {
    "name": "Zayed ID",
    "slug": "zayedid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zayedid.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.zayedid.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "يحتاج التطبيق للوصول إلى الكاميرا لتصوير الروشتة والمنتجات"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "يحتاج التطبيق للوصول إلى موقعك لتحديد عنوان التوصيل"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "يحتاج التطبيق للوصول إلى الميكروفون لتسجيل الملاحظات الصوتية"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "zayedid-project"
      }
    }
  }
}
